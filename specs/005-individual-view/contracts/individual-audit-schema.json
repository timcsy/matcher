{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IndividualAuditSubset (individual-audit/1.0)",
  "description": "個別查詢視圖下載的 audit 子集；只含該角色相關內容。",
  "type": "object",
  "required": [
    "schema_version",
    "record_seed",
    "role_id",
    "role_attributes",
    "role_preferences",
    "assignment",
    "filter_trace_subset",
    "allocation_step"
  ],
  "properties": {
    "schema_version": { "const": "individual-audit/1.0" },
    "record_seed": { "type": "integer" },
    "role_id": { "type": "string" },
    "role_attributes": { "type": "object" },
    "role_preferences": {
      "type": "array",
      "items": { "type": "string" }
    },
    "assignment": {
      "type": "object",
      "required": ["target_id", "target_attributes"],
      "properties": {
        "target_id": { "anyOf": [{ "type": "string" }, { "type": "null" }] },
        "target_attributes": {
          "anyOf": [{ "type": "object" }, { "type": "null" }]
        }
      }
    },
    "filter_trace_subset": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["target_id", "qualified", "matched_rules"],
        "properties": {
          "target_id": { "type": "string" },
          "qualified": { "type": "boolean" },
          "matched_rules": {
            "type": "array",
            "items": { "type": "string" }
          },
          "failed_rule": { "type": "string" }
        }
      }
    },
    "allocation_step": {
      "anyOf": [
        { "type": "null" },
        {
          "type": "object",
          "required": ["step", "role_id", "candidates", "random_index", "chosen", "remaining_capacity_after"]
        }
      ]
    }
  }
}

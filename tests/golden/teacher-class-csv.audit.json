      {
        "key": "assigned_class",
        "label": "分配到的班級",
        "source": "assignment.{role_id}"
      }
    ],
    "rules": [
      {
        "description": "老師的專業必須出現在班級的需要科目清單中",
        "expr": {
          "role_in_target_field": {
            "role_field": "speciality",
            "target_field": "required_subjects"

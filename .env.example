# matcher Web 環境變數範本
# 複製成 .env（已被 .gitignore，不會進 repo），填入實際值。
# 本機開發可用 `uv run uvicorn matcher.web.app:create_app --factory --port 8765`
# （程式啟動會自動讀取同目錄 / 上層的 .env）

# ── Google OAuth（於 Google Cloud Console 建立 OAuth client 後取得）──
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
OAUTH_REDIRECT_URI=http://localhost:8765/auth/callback

# ── session / token 簽章金鑰（自行產生長亂碼）──
# 產生：python -c "import secrets; print(secrets.token_urlsafe(32))"
SESSION_SECRET=change-me-to-a-long-random-string

# ── 本機開發用 http（非 https）時設 1，讓 session cookie 不要求 Secure ──
# 正式部署（https）請移除這行或設 0
MATCHER_INSECURE_COOKIE=1
